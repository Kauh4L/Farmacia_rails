<%= form_for @atendente, :html => { :class => "atendente" } do |f| %>

  <% if @atendente.errors.any? %>
    <div class="alert alert-danger">
      <h5 class="alert-heading"><%= pluralize(@atendente.errors.count, "error") %> prohibited this atendente from being saved:</h5>
      <hr>
      <ul class="mb-0">
      <% @atendente.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :nome, :class => 'form-label' %>
    <%= f.text_field :nome, :class => 'form-control' %>
    <%=f.error_span(:nome) %>
  </div>
  <div class="mb-3">
    <%= f.label :cpf, :class => 'form-label' %>
    <%= f.text_field :cpf, :class => 'form-control' %>
    <%=f.error_span(:cpf) %>
  </div>
  <div class="mb-3">
    <%= f.label :telefone, :class => 'form-label' %>
    <%= f.text_field :telefone, :class => 'form-control' %>
    <%=f.error_span(:telefone) %>
  </div>

  <div class="mb-3">
    <%= f.submit nil, :class => 'btn btn-primary' %>
    <%= link_to t('.cancel', :default => t("helpers.links.cancel")),
              atendentes_path, :class => 'btn btn-secondary' %>
  </div>

<% end %>
