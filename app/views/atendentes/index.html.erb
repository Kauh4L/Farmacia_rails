<p style="color: green"><%= notice %></p>

<% content_for :title, "Atendentes" %>


<h1>PÁGINA DE ATENDENTES</h1>

<div>TABELA DE ATENDENTES</div>

<div id="atendentes">
  <% @atendentes.each do |atendente| %>
    <%= render atendente %>

    <br>
    <table>
      <tr>
        <th>ID</th>
        <th>Nome</th>
        <th>Cpf</th>
        <th>Telefone</th>
      </tr>

      <tr>
        <td><%= atendente.id %></td>
        <td>....</td>
        <td>....</td>
        <td>....</td>
      </tr>
    </table>
    

    <%= link_to "Mostrar", atendente %> |

    <%= link_to "Edit", edit_atendente_path(atendente) %> |

    <%= link_to "Destroy", atendente, method: :delete, data: { confirm: "Are you sure?" } %>
  <br>
  
  <% end %>
</div>

<br>
<%= link_to "New atendente", new_atendente_path %>
