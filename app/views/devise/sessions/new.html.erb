<div class="row justify-content-center mt-3">
  <div class="col-md-5">
    <div class="card shadow-sm border-0">
      <div class="card-body p-4">

        <h2 class="text-center mb-4 fw-bold" style="color: #061A31;">Entrar</h2>

        <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

          <div class="mb-3">
            <%= f.label :email, "E-mail", class: "form-label fw-semibold" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control" %>
          </div>

          <div class="mb-3">
            <%= f.label :password, "Senha", class: "form-label fw-semibold" %>
            <%= f.password_field :password, autocomplete: "current-password", class: "form-control" %>
          </div>

          <% if devise_mapping.rememberable? %>
            <div class="mb-3 form-check">
              <%= f.check_box :remember_me, class: "form-check-input" %>
              <%= f.label :remember_me, "Lembrar de mim", class: "form-check-label" %>
            </div>
          <% end %>

          <div class="d-grid mt-4">
            <%= f.submit "Entrar", class: "btn btn-dark w-100", style: "background-color: #061A31;" %>
          </div>

        <% end %>

        <hr class="my-3">
        <div class="text-center small">
          <%= render "devise/shared/links" %>
        </div>

      </div>
    </div>
  </div>
</div>