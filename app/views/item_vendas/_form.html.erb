<%= form_with(model: item_venda) do |form| %>
  <% if item_venda.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(item_venda.errors.count, "error") %> prohibited this item_venda from being saved:</h2>

      <ul>
        <% item_venda.errors.each do |error| %>
          <li><%= error.full_message %></li>
