<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= content_for?(:title) ? yield(:title) : "Farmacia" %></title>
    <%= csrf_meta_tags %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <%= stylesheet_link_tag "application", :media => "all" %>

    <%= javascript_include_tag "application" %>

      <link rel="preconnect" href="https://fonts.googleapis.com">
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
      <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Poppins:wght@500;700&display=swap" rel="stylesheet">
  </head>
  <body>

    <nav style="background-color: #061A31;" class="navbar navbar-expand-lg navbar-dark">
      <div class="container">
        <a class="navbar-brand" href="/">Farmácia</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav me-auto">
            <li class="nav-item">
              <%= link_to "Página Inicial", root_path, class: "nav-link px-3 mt-1" %>
            </li>
          </ul>
          <ul class="navbar-nav ms-auto">
            <% if user_signed_in? %>
              <li class="nav-item mx-2">
                <span class="nav-link text-white"><%= current_user.email %></span>
              </li>
              <li class="nav-item mx-2">
                <%= button_to "Sair", destroy_user_session_path, method: :delete, class: "btn btn-link nav-link px-2 mt-1", 
                  form_class: "d-inline" %>
              </li>
            <% else %>
              <li class="nav-item">
                <%= link_to "Entrar", new_user_session_path, class: "nav-link px-2 mt-1" %>
              </li>
              <li class="nav-item mx-2">
                <%= link_to "Cadastrar", new_user_registration_path, class: "nav-link px-2 mt-1" %>
              </li>
            <% end %>
            </ul>
          </ul>
        </div>
      </div>
    </nav>

    <div class="container mt-4">
      <%= bootstrap_flash %>
      <%= yield %>
      <br>
      <br>
      <br>
      <br>
      <br>
      <br>
      <footer class="mt-5 py-3 border-top">
        <p class="text-muted">&copy; Teste-Universitário 2026</p>
      </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
