<%- model_class = Medicamento -%>
<div class="d-flex justify-content-between align-items-center mb-4">
  <h1><%=t '.title', :default => model_class.model_name.human.pluralize.titleize %></h1>
  <%= link_to t('.new', :default => t("helpers.links.new")), new_medicamento_path, :class => 'btn btn-primary' %>
  <%= link_to "Download PDF", download_medicamentos_path, class: "btn btn-primary mb-3 ms-2" %>
</div>


<table class="table table-striped table-hover">
  <thead class="table-dark">
    <tr>
      <th><%= model_class.human_attribute_name(:id) %></th>
      <th><%= model_class.human_attribute_name(:nome) %></th>
      <th><%= model_class.human_attribute_name(:preco) %></th>
      <th><%= model_class.human_attribute_name(:estoque) %></th>
      <th><%= model_class.human_attribute_name(:created_at) %></th>
      <th><%=t '.actions', :default => t("helpers.actions") %></th>
    </tr>
  </thead>
  <tbody>
    <% @medicamentos.each do |medicamento| %>
      <tr>
        <td><%= link_to medicamento.id, medicamento_path(medicamento) %></td>
        <td><%= medicamento.nome %></td>
        <td><%= medicamento.preco %></td>
        <td><%= medicamento.estoque %></td>
        <td><%=l medicamento.created_at %></td>
        <td>
          <%= link_to t('.show', :default => t("helpers.links.show")),
                      medicamento_path(medicamento), :class => 'btn btn-sm btn-outline-secondary' %>
          <%= link_to t('.edit', :default => t("helpers.links.edit")),
                      edit_medicamento_path(medicamento), :class => 'btn btn-sm btn-outline-primary' %>
          <%= link_to t('.destroy', :default => t("helpers.links.destroy")),
                      medicamento_path(medicamento),
                      :method => :delete,
                      :data => { :confirm => t('.confirm', :default => t("helpers.links.confirm", :default => 'Are you sure?')) },
                      :class => 'btn btn-sm btn-outline-danger' %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= link_to "Novo Medicamento", new_medicamento_path %>

<div class="d-flex justify-content-center pt-3">
  <%= paginate @medicamentos %>
</div>

<a href="../">Voltar</a>


