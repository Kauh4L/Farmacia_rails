<%- model_class = Medicamento -%>
<div class="page-header">
  <h1><%=t '.title', :default => model_class.model_name.human.titleize %></h1>
</div>

<dl class="row">
  <dt class="col-sm-2"><%= model_class.human_attribute_name(:nome) %>:</dt>
  <dd class="col-sm-10"><%= @medicamento.nome %></dd>
  <dt class="col-sm-2"><%= model_class.human_attribute_name(:preco) %>:</dt>
  <dd class="col-sm-10"><%= @medicamento.preco %></dd>
  <dt class="col-sm-2"><%= model_class.human_attribute_name(:estoque) %>:</dt>
  <dd class="col-sm-10"><%= @medicamento.estoque %></dd>
</dl>

<%= link_to t('.back', :default => t("helpers.links.back")),
              medicamentos_path, :class => 'btn btn-secondary' %>
<%= link_to t('.edit', :default => t("helpers.links.edit")),
              edit_medicamento_path(@medicamento), :class => 'btn btn-secondary' %>
<%= link_to t('.destroy', :default => t("helpers.links.destroy")),
              medicamento_path(@medicamento),
              :method => 'delete',
              :data => { :confirm => t('.confirm', :default => t("helpers.links.confirm", :default => 'Are you sure?')) },
              :class => 'btn btn-danger' %>
