<%= form_with(model: venda) do |form| %>
  <% if venda.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(venda.errors.count, "error") %> prohibited this venda from being saved:</h2>

      <ul>
        <% venda.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div> 
    <%= form.label :atendente_id, style: "display: block" %>
    <%= form.collection_select :atendente_id, Atendente.all, :id, :nome %>
  </div>

  <div>
    <%= form.label :medicamento_id, style: "display: block" %>
    <%= form.collection_select :medicamento_id, Medicamento.all, :id, :nome %>
  </div>

  <div>
    <%= form.label :quantidade, style: "display: block" %>
    <%= form.text_field :quantidade  %>
  </div>

  <div>
    <%= form.submit "FINALIZAR VENDA" %>

  </div>
<% end %>
