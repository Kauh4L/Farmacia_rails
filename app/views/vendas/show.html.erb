<%- model_class = Venda -%>
<div class="page-header">
  <h1><%=t '.title', :default => model_class.model_name.human.titleize %></h1>
</div>

<dl class="row">
  <dt class="col-sm-2"><%= model_class.human_attribute_name(:total) %>:</dt>
  <dd class="col-sm-10"><%= @venda.total %></dd>
  <dt class="col-sm-2"><%= model_class.human_attribute_name(:atendente_id) %>:</dt>
  <dd class="col-sm-10"><%= @venda.atendente_id %></dd>
  <dt class="col-sm-2"><%= model_class.human_attribute_name(:quantidade) %>:</dt>
  <dd class="col-sm-10"><%= @venda.quantidade %></dd>
  <dt class="col-sm-2"><%= model_class.human_attribute_name(:medicamento_id) %>:</dt>
  <dd class="col-sm-10"><%= @venda.medicamento_id %></dd>
  <dt class="col-sm-2"><%= model_class.human_attribute_name(:preco) %>:</dt>
  <dd class="col-sm-10"><%= @venda.preco %></dd>
</dl>

<%= link_to t('.back', :default => t("helpers.links.back")),
              vendas_path, :class => 'btn btn-secondary' %>
<%= link_to t('.edit', :default => t("helpers.links.edit")),
              edit_venda_path(@venda), :class => 'btn btn-secondary' %>
<%= link_to t('.destroy', :default => t("helpers.links.destroy")),
              venda_path(@venda),
              :method => 'delete',
              :data => { :confirm => t('.confirm', :default => t("helpers.links.confirm", :default => 'Are you sure?')) },
              :class => 'btn btn-danger' %>
